                          "id": "3VUz5",
                          "name": "code1",
                          "fill": "#E6EDF3",
                          "content": "function getOrderedItems(menuList, orderedNames, money) {",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "3noGa",
                          "name": "code2",
                          "fill": "#6A9955",
                          "content": "  // 주문한 메뉴만 필터링",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "yQyun",
                          "name": "code3",
                          "fill": "#E6EDF3",
                          "content": "  const orderedItems = menuList.filter(",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "Wk0Zp",
                          "name": "code4",
                          "fill": "#E6EDF3",
                          "content": "    menu => orderedNames.includes(menu.name)",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "bBt55",
                          "name": "code5",
                          "fill": "#E6EDF3",
                          "content": "  );",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "F64Q7",
                          "name": "code6",
                          "fill": "#E6EDF3",
                          "content": " ",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "BWhZU",
                          "name": "code7",
                          "fill": "#6A9955",
                          "content": "  // 총 금액 계산",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "eMQGQ",
                          "name": "code8",
                          "fill": "#E6EDF3",
                          "content": "  const totalPrice = orderedItems.reduce(",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "1wY1e",
                          "name": "code9",
                          "fill": "#E6EDF3",
                          "content": "    (sum, item) => sum + item.price, 0",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "Nzmac",
                          "name": "code10",
                          "fill": "#E6EDF3",
                          "content": "  );",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "nWhzZ",
                          "name": "code11",
                          "fill": "#E6EDF3",
                          "content": " ",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "lg6zM",
                          "name": "code12",
                          "fill": "#6A9955",
                          "content": "  // 총 칼로리 계산",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "QbtDF",
                          "name": "code13",
                          "fill": "#E6EDF3",
                          "content": "  const totalCalories = orderedItems.reduce(",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "vlFUI",
                          "name": "code14",
                          "fill": "#E6EDF3",
                          "content": "    (sum, item) => sum + item.calories, 0",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "gpbR6",
                          "name": "code15",
                          "fill": "#E6EDF3",
                          "content": "  );",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "NpxOw",
                          "name": "code16",
                          "fill": "#E6EDF3",
                          "content": " ",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "8KkIU",
                          "name": "code17",
                          "fill": "#6A9955",
                          "content": "  // 메뉴 이름 추출 및 출력",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "QLjSZ",
                          "name": "code18",
                          "fill": "#E6EDF3",
                          "content": "  const names = orderedItems.map(item => item.name);",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "jq3Pn",
                          "name": "code19",
                          "fill": "#E6EDF3",
                          "content": "  console.log(`주문 메뉴: ${names.join(', ')}`);",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "zDtPq",
                          "name": "code20",
                          "fill": "#E6EDF3",
                          "content": "  console.log(`총 금액: ${totalPrice}원`);",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "1AHYE",
                          "name": "code21",
                          "fill": "#E6EDF3",
                          "content": "  console.log(`총 칼로리: ${totalCalories}kcal`);",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
