                      "children": [
                        {
                          "type": "text",
                          "id": "SK4qL",
                          "fill": "#6A9955",
                          "content": "// 주문을 처리하고 레시피를 발행하는 함수",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "j5G72",
                          "fill": "#6A9955",
                          "content": "// 입력: 주문하고 싶은 메뉴들, 내가 가지고 있는 금액(0원 이상)",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "76Wtq",
                          "fill": "#6A9955",
                          "content": "// 출력: 주문한 메뉴들, 총 결제금액, 거스름 돈, 칼로리, 적립 포인트",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "kB8DN",
                          "fill": "#D4D4D4",
                          "content": "function processOrder(menuList, orderedMenus, money) {",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "VYIae",
                          "fill": "#6A9955",
                          "content": "  // 구매 가능한 메뉴 필터링",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "kyGh5",
                          "fill": "#9CDCFE",
                          "content": "  const availableMenus = filterMenuList(menuList, money);",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "B7p07",
                          "fill": "#D4D4D4",
                          "content": " ",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "GBsRi",
                          "fill": "#D4D4D4",
                          "content": " ",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "YUSk5",
                          "fill": "#D4D4D4",
                          "content": " ",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "RcSST",
                          "fill": "#D4D4D4",
                          "content": " ",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "8GRwe",
                          "fill": "#6A9955",
                          "content": "  // '구매 가능한 메뉴' 중에서 주문한 메뉴 정보 가져오기",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "RbHMv",
                          "fill": "#9CDCFE",
                          "content": "  const orderedItems = menuList.filter((menu) => availableMenus.includes(menu.name);",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "LZxdp",
                          "fill": "#D4D4D4",
                          "content": " ",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "R3i66",
                          "fill": "#D4D4D4",
                          "content": " ",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "Jtvnf",
                          "fill": "#D4D4D4",
                          "content": " ",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "NPmbl",
                          "fill": "#D4D4D4",
                          "content": " ",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "ESZNA",
                          "fill": "#6A9955",
                          "content": "  // 총 주문 금액 계산",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "xW9Ng",
                          "fill": "#9CDCFE",
                          "content": "  let totalPrice = 0;",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "lR8Mh",
                          "fill": "#D4D4D4",
                          "content": "  for (let i = 0; i < orderedItems.length; i++) {",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "59Nws",
                          "fill": "#D4D4D4",
                          "content": "    totalPrice += orderedItems[i].price;",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "ooKUE",
                          "fill": "#D4D4D4",
                          "content": "  }",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "IW4CD",
                          "fill": "#D4D4D4",
                          "content": " ",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "1tjbj",
                          "fill": "#6A9955",
                          "content": "  // 총 칼로리 계산 (유틸 함수 재사용을 유도하기 위해)",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "ytUu4",
                          "fill": "#6A9955",
                          "content": "  // ❓ 칼로리 계산이 '주문'하는 책임에 포함될까?",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "K4zgs",
                          "fill": "#9CDCFE",
                          "content": "  let totalKcal = 0;",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "VsN6U",
                          "fill": "#D4D4D4",
                          "content": "  for (let i = 0; i < orderedItems.length; i++) {",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "oXnBy",
                          "fill": "#D4D4D4",
                          "content": "    totalKcal += orderedItems[i].kcal;",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "Pcnm0",
                          "fill": "#D4D4D4",
                          "content": "  }",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "EPyEJ",
                          "fill": "#D4D4D4",
                          "content": " ",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "CSnPG",
                          "fill": "#D4D4D4",
                          "content": " ",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "2mDho",
                          "fill": "#D4D4D4",
                          "content": " ",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "LcSYk",
                          "fill": "#6A9955",
                          "content": "  // 적립 포인트 및 거스름돈 계산",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "puNxx",
                          "fill": "#9CDCFE",
                          "content": "  const point = totalPrice * 0.1;",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "R5Tog",
                          "fill": "#9CDCFE",
                          "content": "  const change = money - totalPrice;",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "jysfC",
                          "fill": "#D4D4D4",
                          "content": " ",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "hFWm2",
                          "fill": "#D4D4D4",
                          "content": " ",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "WeEqq",
                          "fill": "#D4D4D4",
                          "content": " ",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "X5Z4t",
                          "fill": "#D4D4D4",
                          "content": " ",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "bqhRb",
                          "fill": "#6A9955",
                          "content": "  // 메뉴 이름만 추출",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "GAsJo",
                          "fill": "#9CDCFE",
                          "content": "  let orderedMenuNames = [];",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "yX66N",
                          "fill": "#D4D4D4",
                          "content": "  for (let i = 0; i < orderedItems.length; i++) {",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "gKR0u",
                          "fill": "#D4D4D4",
                          "content": "    orderedMenuNames.push(orderedItems[i].name);",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "jzVe1",
                          "fill": "#D4D4D4",
                          "content": "  }",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "XTXSs",
                          "fill": "#D4D4D4",
                          "content": " ",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "ODcxR",
                          "fill": "#D4D4D4",
                          "content": " ",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "U8kcd",
                          "fill": "#D4D4D4",
                          "content": " ",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "bj4B3",
                          "fill": "#6A9955",
                          "content": "  // 최종 결과 출력",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "otg3t",
                          "fill": "#D4D4D4",
                          "content": "  console.log(\"주문 내역:\", orderedMenuNames.join(\", \"));",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "Pg6dq",
                          "fill": "#D4D4D4",
                          "content": "  console.log(\"결제 금액:\", totalPrice, \"원\");",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "aVOm8",
                          "fill": "#D4D4D4",
                          "content": "  console.log(\"총 칼로리:\", totalKcal, \"kcal\");",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "JIXzm",
                          "fill": "#D4D4D4",
                          "content": "  console.log(\"거스름돈:\", change, \"원\");",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "ZZmY2",
                          "fill": "#D4D4D4",
                          "content": "  console.log(\"적립 포인트:\", point, \"점\");",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "XRnOz",
                          "fill": "#D4D4D4",
                          "content": "}",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "9Oh29",
                          "fill": "#D4D4D4",
                          "content": " ",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
