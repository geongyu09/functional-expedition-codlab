                        },
                        {
                          "type": "text",
                          "id": "4RCLI",
                          "fill": "#6A9955",
                          "content": "  // 최종 결과 출력",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "zTTPT",
                          "fill": "#D4D4D4",
                          "content": "  console.log(\"주문 내역:\", orderedMenuNames.join(\", \"));",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "GWf1l",
                          "fill": "#D4D4D4",
                          "content": "  console.log(\"결제 금액:\", totalPrice, \"원\");",
