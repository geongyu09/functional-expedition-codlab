                        {
                          "type": "text",
                          "id": "F8NCF",
                          "name": "code1",
                          "fill": "#E6EDF3",
                          "content": "function getOrderedItems(menuList, orderedNames, money) {",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "TcfqX",
                          "name": "code2",
                          "fill": "#6A9955",
                          "content": "  // 주문한 메뉴만 필터링",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "ksYO5",
                          "name": "code3",
                          "fill": "#E6EDF3",
                          "content": "  const orderedItems = menuList.filter(",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "TyqNl",
                          "name": "code4",
                          "fill": "#E6EDF3",
                          "content": "    menu => orderedNames.includes(menu.name)",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "h2frj",
                          "name": "code5",
                          "fill": "#E6EDF3",
                          "content": "  );",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "IWtPJ",
                          "name": "code6",
                          "fill": "#E6EDF3",
                          "content": " ",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "Ja58g",
                          "name": "code7",
                          "fill": "#6A9955",
                          "content": "  // 총 금액 계산",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "0rYyq",
                          "name": "code8",
                          "fill": "#E6EDF3",
                          "content": "  const totalPrice = orderedItems.reduce(",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "G03M5",
                          "name": "code9",
                          "fill": "#E6EDF3",
                          "content": "    (sum, item) => sum + item.price, 0",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "EQWGp",
                          "name": "code10",
                          "fill": "#E6EDF3",
                          "content": "  );",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "LwetA",
                          "name": "code11",
                          "fill": "#E6EDF3",
                          "content": " ",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "HurYj",
                          "name": "code12",
                          "fill": "#6A9955",
                          "content": "  // 총 칼로리 계산",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "BfViy",
                          "name": "code13",
                          "fill": "#E6EDF3",
                          "content": "  const totalCalories = orderedItems.reduce(",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "TN62E",
                          "name": "code14",
                          "fill": "#E6EDF3",
                          "content": "    (sum, item) => sum + item.calories, 0",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "rd14V",
                          "name": "code15",
                          "fill": "#E6EDF3",
                          "content": "  );",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "8bPI1",
                          "name": "code16",
                          "fill": "#E6EDF3",
                          "content": " ",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "gmqRq",
                          "name": "code17",
                          "fill": "#6A9955",
                          "content": "  // 메뉴 이름 추출 및 출력",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "TBZzO",
                          "name": "code18",
                          "fill": "#E6EDF3",
                          "content": "  const names = orderedItems.map(item => item.name);",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "6brcX",
                          "name": "code19",
                          "fill": "#E6EDF3",
                          "content": "  console.log(`주문 메뉴: ${names.join(', ')}`);",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "YKUIo",
                          "name": "code20",
                          "fill": "#E6EDF3",
                          "content": "  console.log(`총 금액: ${totalPrice}원`);",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "ZcdJ5",
                          "name": "code21",
                          "fill": "#E6EDF3",
                          "content": "  console.log(`총 칼로리: ${totalCalories}kcal`);",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "ReGnc",
                          "name": "code22",
                          "fill": "#E6EDF3",
                          "content": " ",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "5gdEs",
                          "name": "code23",
                          "fill": "#6A9955",
                          "content": "  // 거스름돈 계산",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "IqUxw",
                          "name": "code24",
                          "fill": "#E6EDF3",
                          "content": "  const change = money - totalPrice;",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "38uhj",
                          "name": "code25",
                          "fill": "#E6EDF3",
                          "content": "  console.log(`거스름돈: ${change}원`);",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "NLjzp",
                          "name": "code26",
                          "fill": "#E6EDF3",
                          "content": "}",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        }
                      ]
