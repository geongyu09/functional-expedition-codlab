                          "content": "  const totalKcal = calculateTotalKcal(orderedItems);",
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 11,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "uYIL3",
                          "name": "l13",
                          "fill": "#E6EDF3",
                          "content": " ",
