                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "FTwFJ",
                          "name": "l16",
                          "fill": "#E6EDF3",
                          "content": "  const change = calculateChange(money, totalPrice);",
                          "fontFamily": "JetBrains Mono",
