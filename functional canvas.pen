                        {
                          "type": "text",
                          "id": "57KkV",
                          "fill": "#6A9955",
                          "content": "// 주문을 처리하고 레시피를 발행하는 함수",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "deUSA",
                          "fill": "#6A9955",
                          "content": "// 입력: 주문하고 싶은 메뉴들, 내가 가지고 있는 금액(0원 이상)",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "FvqMN",
                          "fill": "#6A9955",
                          "content": "// 출력: 주문한 메뉴들, 총 결제금액, 거스름 돈, 칼로리, 적립 포인트",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "SdowD",
                          "fill": "#D4D4D4",
                          "content": "function processOrder(menuList, orderedMenus, money) {",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "qR1MB",
                          "fill": "#6A9955",
                          "content": "  // 구매 가능한 메뉴 필터링",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "0o9fe",
                          "fill": "#9CDCFE",
                          "content": "  const availableMenus = filterMenuList(menuList, money);",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "UouzK",
                          "fill": "#D4D4D4",
                          "content": " ",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "pFuMp",
                          "fill": "#D4D4D4",
                          "content": " ",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "sfm3Z",
                          "fill": "#D4D4D4",
                          "content": " ",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "HCyfN",
                          "fill": "#D4D4D4",
                          "content": " ",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "pYwD2",
                          "fill": "#6A9955",
                          "content": "  // '구매 가능한 메뉴' 중에서 주문한 메뉴 정보 가져오기",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "LOLKS",
                          "fill": "#9CDCFE",
                          "content": "  const orderedItems = menuList.filter((menu) => availableMenus.includes(menu.name);",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "qCKxb",
                          "fill": "#D4D4D4",
                          "content": " ",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "2k5TI",
                          "fill": "#D4D4D4",
                          "content": " ",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "XL0hb",
                          "fill": "#D4D4D4",
                          "content": " ",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "8hTAM",
                          "fill": "#D4D4D4",
                          "content": " ",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "TggVP",
                          "fill": "#6A9955",
                          "content": "  // 총 주문 금액 계산",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "qbBmd",
                          "fill": "#9CDCFE",
                          "content": "  let totalPrice = 0;",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "4czKf",
                          "fill": "#D4D4D4",
                          "content": "  for (let i = 0; i < orderedItems.length; i++) {",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "vDW0W",
                          "fill": "#D4D4D4",
                          "content": "    totalPrice += orderedItems[i].price;",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "Ck2Dy",
                          "fill": "#D4D4D4",
                          "content": "  }",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "Z3rQX",
                          "fill": "#D4D4D4",
                          "content": " ",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "kmSmo",
                          "fill": "#6A9955",
                          "content": "  // 총 칼로리 계산 (유틸 함수 재사용을 유도하기 위해)",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "Sf1Uw",
                          "fill": "#6A9955",
                          "content": "  // ❓ 칼로리 계산이 '주문'하는 책임에 포함될까?",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "XoxF1",
                          "fill": "#9CDCFE",
                          "content": "  let totalKcal = 0;",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "XN7uE",
                          "fill": "#D4D4D4",
                          "content": "  for (let i = 0; i < orderedItems.length; i++) {",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "ffNUF",
                          "fill": "#D4D4D4",
                          "content": "    totalKcal += orderedItems[i].kcal;",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "YUk1u",
                          "fill": "#D4D4D4",
                          "content": "  }",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "LeCkD",
                          "fill": "#D4D4D4",
                          "content": " ",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "xIYOT",
                          "fill": "#D4D4D4",
                          "content": " ",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "obhfW",
                          "fill": "#D4D4D4",
                          "content": " ",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "Yfy5W",
                          "fill": "#6A9955",
                          "content": "  // 적립 포인트 및 거스름돈 계산",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "3ylCA",
                          "fill": "#9CDCFE",
                          "content": "  const point = totalPrice * 0.1;",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "zq0jn",
                          "fill": "#9CDCFE",
                          "content": "  const change = money - totalPrice;",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "lPfFZ",
                          "fill": "#D4D4D4",
                          "content": " ",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
