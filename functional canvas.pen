                    {
                      "type": "text",
                      "id": "Fpy0w",
                      "name": "codeLine1",
                      "fill": "#E6EDF3",
                      "content": "function addItem(cart, item) {",
                      "fontFamily": "JetBrains Mono",
                      "fontSize": 13,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "sK3eE",
                      "name": "codeLine2",
                      "fill": "#FFA657",
                      "content": "  const total = item.price * item.qty;",
                      "fontFamily": "JetBrains Mono",
                      "fontSize": 13,
                      "fontWeight": "700"
                    },
                    {
                      "type": "text",
                      "id": "HU3a8",
                      "name": "codeLine3",
                      "fill": "#E6EDF3",
                      "content": "  cart.items.push(item);",
                      "fontFamily": "JetBrains Mono",
                      "fontSize": 13,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "tqYPG",
                      "name": "codeLine4",
                      "fill": "#E6EDF3",
                      "content": "  cart.total += total;",
                      "fontFamily": "JetBrains Mono",
                      "fontSize": 13,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "eQsHn",
                      "name": "codeLine5",
                      "fill": "#E6EDF3",
                      "content": "  return cart;",
                      "fontFamily": "JetBrains Mono",
                      "fontSize": 13,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "GTcbu",
                      "name": "codeLine6",
