                        },
                        {
                          "type": "text",
                          "id": "srisQ",
                          "name": "l14",
                          "fill": "#8B949E",
                          "content": "  // 적립 포인트 및 거스름돈 계산",
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 11,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "vCVT7",
                          "name": "l15",
                          "fill": "#E6EDF3",
                          "content": "  const point = calculatePoint(totalPrice);",
                          "fontFamily": "JetBrains Mono",
