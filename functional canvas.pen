                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "LccAQ",
                          "fill": "#D4D4D4",
                          "content": " ",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "gP10D",
                          "fill": "#6A9955",
                          "content": "  // 최종 결과 출력",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "zf78h",
                          "fill": "#D4D4D4",
                          "content": "  console.log(\"주문 내역:\", orderedMenuNames.join(\", \"));",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "Q86IQ",
                          "fill": "#D4D4D4",
                          "content": "  console.log(\"결제 금액:\", totalPrice, \"원\");",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "Kad8o",
                          "fill": "#D4D4D4",
                          "content": "  console.log(\"총 칼로리:\", totalKcal, \"kcal\");",
                          "fontFamily": "Fira Code",
