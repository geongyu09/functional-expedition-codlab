                      ],
                      "children": [
                        {
                          "type": "text",
                          "id": "pMZ0s",
                          "name": "code1",
                          "fill": "#E6EDF3",
                          "content": "function getOrderedItems(menuList, orderedNames, money) {",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "h6pLB",
                          "name": "code2",
                          "fill": "#6A9955",
                          "content": "  // 주문한 메뉴만 필터링",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "gZNx4",
                          "name": "code3",
                          "fill": "#E6EDF3",
                          "content": "  const orderedItems = menuList.filter(",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "4XUUh",
                          "name": "code4",
                          "fill": "#E6EDF3",
                          "content": "    menu => orderedNames.includes(menu.name)",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "u8SfE",
                          "name": "code5",
                          "fill": "#E6EDF3",
                          "content": "  );",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "ax3Vj",
                          "name": "code6",
                          "fill": "#E6EDF3",
                          "content": " ",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "vsdSn",
                          "name": "code7",
                          "fill": "#6A9955",
                          "content": "  // 총 금액 계산",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "ff9Pv",
                          "name": "code8",
                          "fill": "#E6EDF3",
                          "content": "  const totalPrice = orderedItems.reduce(",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "L18UN",
                          "name": "code9",
                          "fill": "#E6EDF3",
                          "content": "    (sum, item) => sum + item.price, 0",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "xOiTH",
                          "name": "code10",
                          "fill": "#E6EDF3",
                          "content": "  );",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "HOxSU",
                          "name": "code11",
                          "fill": "#E6EDF3",
                          "content": " ",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "l7sR0",
                          "name": "code12",
                          "fill": "#6A9955",
                          "content": "  // 총 칼로리 계산",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "XCAfk",
                          "name": "code13",
                          "fill": "#E6EDF3",
                          "content": "  const totalCalories = orderedItems.reduce(",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "h01i7",
                          "name": "code14",
                          "fill": "#E6EDF3",
                          "content": "    (sum, item) => sum + item.calories, 0",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "UddHB",
                          "name": "code15",
                          "fill": "#E6EDF3",
                          "content": "  );",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "Rurkq",
                          "name": "code16",
                          "fill": "#E6EDF3",
                          "content": " ",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "0rZV4",
                          "name": "code17",
                          "fill": "#6A9955",
                          "content": "  // 메뉴 이름 추출 및 출력",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "Lk4rO",
                          "name": "code18",
                          "fill": "#E6EDF3",
                          "content": "  const names = orderedItems.map(item => item.name);",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "FWRw9",
                          "name": "code19",
                          "fill": "#E6EDF3",
                          "content": "  console.log(`주문 메뉴: ${names.join(', ')}`);",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "gc1NZ",
                          "name": "code20",
                          "fill": "#E6EDF3",
                          "content": "  console.log(`총 금액: ${totalPrice}원`);",
