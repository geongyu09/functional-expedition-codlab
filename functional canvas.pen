                        {
                          "type": "text",
                          "id": "M9Kql",
                          "name": "l1",
                          "fill": "#E6EDF3",
                          "content": "function processOrder(menuList, orderedMenus, money) {",
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 11,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "8DLkd",
                          "name": "l2",
                          "fill": "#8B949E",
                          "content": "  // 구매 가능한 메뉴 필터링",
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 11,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "EWyZq",
                          "name": "l3",
                          "fill": "#E6EDF3",
                          "content": "  const availableMenus = filterMenuList(menuList, money);",
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 11,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "OMmgn",
                          "name": "l4",
                          "fill": "#E6EDF3",
                          "content": " ",
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 11,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "PhjN9",
                          "name": "l5",
                          "fill": "#8B949E",
                          "content": "  // '구매 가능한 메뉴' 중에서 주문한 메뉴 정보 가져오기",
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 11,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "V3sJv",
                          "name": "l6",
                          "fill": "#E6EDF3",
                          "content": "  const orderedItems = getOrderedItems(availableMenus, orderedMenus);",
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 11,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "FqzgQ",
                          "name": "l7",
                          "fill": "#E6EDF3",
                          "content": " ",
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 11,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "h2Tyv",
                          "name": "l8",
                          "fill": "#8B949E",
                          "content": "  // 총 주문 금액 계산",
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 11,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "HAmYa",
                          "name": "l9",
                          "fill": "#E6EDF3",
                          "content": "  const totalPrice = calculateTotalPrice(orderedItems);",
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 11,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "MUwW1",
                          "name": "l10",
                          "fill": "#E6EDF3",
                          "content": " ",
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 11,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "tK1lL",
                          "name": "l11",
                          "fill": "#8B949E",
