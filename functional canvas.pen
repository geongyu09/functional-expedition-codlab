                        },
                        {
                          "type": "text",
                          "id": "bUVHn",
                          "name": "code23",
                          "fill": "#6A9955",
                          "content": "  // 거스름돈 계산",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "Vd7C7",
                          "name": "code24",
                          "fill": "#E6EDF3",
                          "content": "  const change = money - totalPrice;",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "OeUi6",
                          "name": "code25",
