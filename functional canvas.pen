                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "1xEzX",
                          "fill": "#D4D4D4",
                          "content": " ",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "fmyqT",
                          "fill": "#6A9955",
                          "content": "  // 메뉴 이름만 추출",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "N7hEO",
                          "fill": "#9CDCFE",
                          "content": "  let orderedMenuNames = [];",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "myUso",
                          "fill": "#D4D4D4",
                          "content": "  for (let i = 0; i < orderedItems.length; i++) {",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "M6d0S",
                          "fill": "#D4D4D4",
                          "content": "    orderedMenuNames.push(orderedItems[i].name);",
                          "fontFamily": "Fira Code",
