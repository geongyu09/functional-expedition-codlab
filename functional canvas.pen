                      ],
                      "children": [
                        {
                          "type": "text",
                          "id": "cUkI0",
                          "fill": "#6A9955",
                          "content": "// 주문을 처리하고 레시피를 발행하는 함수",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "Pxz9j",
                          "fill": "#6A9955",
                          "content": "// 입력: 주문하고 싶은 메뉴들, 내가 가지고 있는 금액(0원 이상)",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "zXji9",
                          "fill": "#6A9955",
                          "content": "// 출력: 주문한 메뉴들, 총 결제금액, 거스름 돈, 칼로리, 적립 포인트",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "DEp52",
                          "fill": "#D4D4D4",
                          "content": "function processOrder(menuList, orderedMenus, money) {",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "xgejS",
                          "fill": "#6A9955",
                          "content": "  // 구매 가능한 메뉴 필터링",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "Vorzm",
                          "fill": "#9CDCFE",
                          "content": "  const availableMenus = filterMenuList(menuList, money);",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "nPpLw",
                          "fill": "#D4D4D4",
                          "content": " ",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "ZgG3c",
                          "fill": "#D4D4D4",
                          "content": " ",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "zzjwt",
                          "fill": "#D4D4D4",
                          "content": " ",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "ro1Mn",
                          "fill": "#D4D4D4",
                          "content": " ",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "PLbp8",
                          "fill": "#6A9955",
                          "content": "  // '구매 가능한 메뉴' 중에서 주문한 메뉴 정보 가져오기",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "LvGLJ",
                          "fill": "#9CDCFE",
                          "content": "  const orderedItems = menuList.filter((menu) => availableMenus.includes(menu.name);",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "PMJR3",
                          "fill": "#D4D4D4",
                          "content": " ",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "fMzPi",
                          "fill": "#D4D4D4",
                          "content": " ",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "Y894p",
                          "fill": "#D4D4D4",
                          "content": " ",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "zVtkD",
                          "fill": "#D4D4D4",
                          "content": " ",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "yZmnY",
                          "fill": "#6A9955",
                          "content": "  // 총 주문 금액 계산",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "f12sE",
                          "fill": "#9CDCFE",
                          "content": "  let totalPrice = 0;",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "ENqfJ",
                          "fill": "#D4D4D4",
                          "content": "  for (let i = 0; i < orderedItems.length; i++) {",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "axK8S",
                          "fill": "#D4D4D4",
                          "content": "    totalPrice += orderedItems[i].price;",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "cKnrU",
                          "fill": "#D4D4D4",
                          "content": "  }",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "QkUKD",
                          "fill": "#D4D4D4",
                          "content": " ",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "VI2lp",
                          "fill": "#6A9955",
                          "content": "  // 총 칼로리 계산 (유틸 함수 재사용을 유도하기 위해)",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "c9T41",
                          "fill": "#6A9955",
                          "content": "  // ❓ 칼로리 계산이 '주문'하는 책임에 포함될까?",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "9ylTJ",
                          "fill": "#9CDCFE",
                          "content": "  let totalKcal = 0;",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "xdg2z",
                          "fill": "#D4D4D4",
                          "content": "  for (let i = 0; i < orderedItems.length; i++) {",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "EBoxh",
                          "fill": "#D4D4D4",
                          "content": "    totalKcal += orderedItems[i].kcal;",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "Dm3Iv",
                          "fill": "#D4D4D4",
                          "content": "  }",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "7xPYZ",
                          "fill": "#D4D4D4",
                          "content": " ",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "IxZc3",
                          "fill": "#D4D4D4",
                          "content": " ",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "KPqyJ",
                          "fill": "#D4D4D4",
                          "content": " ",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "vcLsw",
                          "fill": "#6A9955",
                          "content": "  // 적립 포인트 및 거스름돈 계산",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "rX3Pc",
                          "fill": "#9CDCFE",
                          "content": "  const point = totalPrice * 0.1;",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "XbKQa",
                          "fill": "#9CDCFE",
                          "content": "  const change = money - totalPrice;",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "GhxvC",
                          "fill": "#D4D4D4",
                          "content": " ",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "NBZai",
                          "fill": "#D4D4D4",
                          "content": " ",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "rui6l",
                          "fill": "#D4D4D4",
                          "content": " ",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "P88pu",
                          "fill": "#D4D4D4",
                          "content": " ",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "6GJrM",
                          "fill": "#6A9955",
                          "content": "  // 메뉴 이름만 추출",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "pzxRT",
                          "fill": "#9CDCFE",
                          "content": "  let orderedMenuNames = [];",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "4BigE",
                          "fill": "#D4D4D4",
                          "content": "  for (let i = 0; i < orderedItems.length; i++) {",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "begaz",
                          "fill": "#D4D4D4",
                          "content": "    orderedMenuNames.push(orderedItems[i].name);",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
