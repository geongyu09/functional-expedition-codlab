                                {
                                  "type": "text",
                                  "id": "xN5ZT",
                                  "name": "lc1",
                                  "fill": "#6A9955",
                                  "content": "// Array Sort Utility",
                                  "lineHeight": 1.5,
                                  "fontFamily": "Fira Code",
                                  "fontSize": 13,
                                  "fontWeight": "normal"
                                },
                                {
                                  "type": "text",
                                  "id": "1gvnw",
                                  "name": "lc2",
                                  "fill": "#6A9955",
                                  "content": "// Sorts arrays efficiently",
                                  "lineHeight": 1.5,
                                  "fontFamily": "Fira Code",
                                  "fontSize": 13,
                                  "fontWeight": "normal"
                                },
                                {
                                  "type": "text",
                                  "id": "hlnHT",
                                  "name": "lc3",
                                  "fill": "#E6EDF3",
                                  "content": " ",
                                  "lineHeight": 1.5,
                                  "fontFamily": "Fira Code",
                                  "fontSize": 13,
                                  "fontWeight": "normal"
                                },
                                {
                                  "type": "text",
                                  "id": "GuQE7",
                                  "name": "lc4",
                                  "fill": "#E6EDF3",
                                  "content": "function quickSort(arr) {",
                                  "lineHeight": 1.5,
                                  "fontFamily": "Fira Code",
                                  "fontSize": 13,
                                  "fontWeight": "normal"
                                },
                                {
                                  "type": "text",
                                  "id": "OYmte",
                                  "name": "lc5",
                                  "fill": "#E6EDF3",
                                  "content": "  if (arr.length <= 1) {",
                                  "lineHeight": 1.5,
                                  "fontFamily": "Fira Code",
                                  "fontSize": 13,
                                  "fontWeight": "normal"
                                },
                                {
                                  "type": "text",
                                  "id": "bSQKg",
                                  "name": "lc6",
                                  "fill": "#E6EDF3",
                                  "content": "    return arr;",
                                  "lineHeight": 1.5,
                                  "fontFamily": "Fira Code",
                                  "fontSize": 13,
                                  "fontWeight": "normal"
                                },
                                {
                                  "type": "text",
                                  "id": "NvK3j",
                                  "name": "lc7",
                                  "fill": "#E6EDF3",
                                  "content": "  }",
                                  "lineHeight": 1.5,
                                  "fontFamily": "Fira Code",
                                  "fontSize": 13,
                                  "fontWeight": "normal"
                                },
                                {
                                  "type": "text",
                                  "id": "sz16S",
                                  "name": "lc8",
                                  "fill": "#E6EDF3",
                                  "content": " ",
                                  "lineHeight": 1.5,
                                  "fontFamily": "Fira Code",
                                  "fontSize": 13,
                                  "fontWeight": "normal"
                                },
                                {
                                  "type": "text",
                                  "id": "f4yJF",
                                  "name": "lc9",
                                  "fill": "#E6EDF3",
                                  "content": "  const pivot = arr[0];",
                                  "lineHeight": 1.5,
                                  "fontFamily": "Fira Code",
                                  "fontSize": 13,
                                  "fontWeight": "normal"
                                },
                                {
                                  "type": "text",
                                  "id": "Swmjh",
                                  "name": "lc10",
                                  "fill": "#E6EDF3",
                                  "content": "  const left = [];",
                                  "lineHeight": 1.5,
                                  "fontFamily": "Fira Code",
                                  "fontSize": 13,
                                  "fontWeight": "normal"
                                },
                                {
                                  "type": "text",
                                  "id": "NdQJh",
                                  "name": "lc11",
                                  "fill": "#E6EDF3",
                                  "content": "  const right = [];",
                                  "lineHeight": 1.5,
                                  "fontFamily": "Fira Code",
                                  "fontSize": 13,
                                  "fontWeight": "normal"
                                },
                                {
                                  "type": "text",
                                  "id": "OeVi4",
                                  "name": "lc12",
                                  "fill": "#E6EDF3",
                                  "content": " ",
                                  "lineHeight": 1.5,
                                  "fontFamily": "Fira Code",
                                  "fontSize": 13,
                                  "fontWeight": "normal"
                                },
                                {
                                  "type": "text",
                                  "id": "cSI9I",
                                  "name": "lc13",
                                  "fill": "#E6EDF3",
                                  "content": "  for (let i = 1; i < arr.length; i++) {",
                                  "lineHeight": 1.5,
                                  "fontFamily": "Fira Code",
                                  "fontSize": 13,
                                  "fontWeight": "normal"
                                },
                                {
                                  "type": "text",
                                  "id": "BFFvx",
                                  "name": "lc14",
                                  "fill": "#E6EDF3",
                                  "content": "    if (arr[i] < pivot) {",
                                  "lineHeight": 1.5,
                                  "fontFamily": "Fira Code",
                                  "fontSize": 13,
                                  "fontWeight": "normal"
                                },
                                {
                                  "type": "text",
                                  "id": "7viFR",
                                  "name": "lc15",
                                  "fill": "#E6EDF3",
                                  "content": "      left.push(arr[i]);",
                                  "lineHeight": 1.5,
                                  "fontFamily": "Fira Code",
                                  "fontSize": 13,
                                  "fontWeight": "normal"
                                }
                              ]
                            }
                          ]
                        },
