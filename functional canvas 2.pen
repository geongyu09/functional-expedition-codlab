                    },
                    {
                      "type": "text",
                      "id": "VQfCL",
                      "name": "c3",
                      "fill": "#E6EDF3",
                      "content": "function subtract(a, b){",
                      "fontFamily": "JetBrains Mono",
                      "fontSize": 11,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "JXVPm",
