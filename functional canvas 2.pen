                        },
                        {
                          "type": "text",
                          "id": "f1LDI",
                          "name": "code23",
                          "fill": "#6A9955",
                          "content": "  // 거스름돈 계산",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "P6Uzm",
                          "name": "code24",
                          "fill": "#E6EDF3",
                          "content": "  const change = money - totalPrice;",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "oOyZa",
                          "name": "code25",
                          "fill": "#E6EDF3",
