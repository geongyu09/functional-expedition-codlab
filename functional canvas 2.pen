                          "type": "text",
                          "id": "5oBBL",
                          "name": "code1",
                          "fill": "#E6EDF3",
                          "content": "function getOrderedItems(menuList, orderedNames, money) {",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "1z1ys",
                          "name": "code2",
                          "fill": "#6A9955",
                          "content": "  // 주문한 메뉴만 필터링",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "gi6Jq",
                          "name": "code3",
                          "fill": "#E6EDF3",
                          "content": "  const orderedItems = menuList.filter(",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "AqnyK",
                          "name": "code4",
                          "fill": "#E6EDF3",
                          "content": "    menu => orderedNames.includes(menu.name)",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "nn05p",
                          "name": "code5",
                          "fill": "#E6EDF3",
                          "content": "  );",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "jauFc",
                          "name": "code6",
                          "fill": "#E6EDF3",
                          "content": " ",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "docm8",
                          "name": "code7",
                          "fill": "#6A9955",
                          "content": "  // 총 금액 계산",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "rHJdm",
                          "name": "code8",
                          "fill": "#E6EDF3",
                          "content": "  const totalPrice = orderedItems.reduce(",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "7ib0t",
                          "name": "code9",
                          "fill": "#E6EDF3",
                          "content": "    (sum, item) => sum + item.price, 0",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "uIeLg",
                          "name": "code10",
                          "fill": "#E6EDF3",
                          "content": "  );",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "XOFTK",
                          "name": "code11",
                          "fill": "#E6EDF3",
                          "content": " ",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "dDYCx",
                          "name": "code12",
                          "fill": "#6A9955",
                          "content": "  // 총 칼로리 계산",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "bp7im",
                          "name": "code13",
                          "fill": "#E6EDF3",
                          "content": "  const totalCalories = orderedItems.reduce(",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "XhqFa",
                          "name": "code14",
                          "fill": "#E6EDF3",
                          "content": "    (sum, item) => sum + item.calories, 0",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "rGDqy",
                          "name": "code15",
                          "fill": "#E6EDF3",
                          "content": "  );",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "LylcB",
                          "name": "code16",
                          "fill": "#E6EDF3",
                          "content": " ",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "sItHa",
                          "name": "code17",
                          "fill": "#6A9955",
                          "content": "  // 메뉴 이름 추출 및 출력",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "Bxj6O",
                          "name": "code18",
                          "fill": "#E6EDF3",
                          "content": "  const names = orderedItems.map(item => item.name);",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "MngrM",
                          "name": "code19",
                          "fill": "#E6EDF3",
                          "content": "  console.log(`주문 메뉴: ${names.join(', ')}`);",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "ge8cj",
                          "name": "code20",
                          "fill": "#E6EDF3",
                          "content": "  console.log(`총 금액: ${totalPrice}원`);",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "LT2co",
                          "name": "code21",
                          "fill": "#E6EDF3",
                          "content": "  console.log(`총 칼로리: ${totalCalories}kcal`);",
                          "fontFamily": "Fira Code",
                          "fontSize": 13,
