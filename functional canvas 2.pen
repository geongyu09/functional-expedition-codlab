                            {
                              "type": "text",
                              "id": "fYauP",
                              "name": "code1",
                              "fill": "#E6EDF3",
                              "content": "function getOrderedItems(menuList, orderedNames, money) {",
                              "fontFamily": "Fira Code",
                              "fontSize": 13,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "text",
                              "id": "8D21I",
                              "name": "code2",
                              "fill": "#6A9955",
                              "content": "  // 주문한 메뉴만 필터링",
                              "fontFamily": "Fira Code",
                              "fontSize": 13,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "text",
                              "id": "hcfQe",
                              "name": "code3",
                              "fill": "#E6EDF3",
                              "content": "  const orderedItems = menuList.filter(",
                              "fontFamily": "Fira Code",
                              "fontSize": 13,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "text",
                              "id": "7f2n6",
                              "name": "code4",
                              "fill": "#E6EDF3",
                              "content": "    menu => orderedNames.includes(menu.name)",
                              "fontFamily": "Fira Code",
                              "fontSize": 13,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "text",
                              "id": "yx8XU",
                              "name": "code5",
                              "fill": "#E6EDF3",
                              "content": "  );",
                              "fontFamily": "Fira Code",
                              "fontSize": 13,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "text",
                              "id": "6uhQY",
                              "name": "code6",
                              "fill": "#E6EDF3",
                              "content": " ",
                              "fontFamily": "Fira Code",
                              "fontSize": 13,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "text",
                              "id": "J4LHX",
                              "name": "code7",
                              "fill": "#6A9955",
                              "content": "  // 총 금액 계산",
                              "fontFamily": "Fira Code",
                              "fontSize": 13,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "text",
                              "id": "fnTdl",
                              "name": "code8",
                              "fill": "#E6EDF3",
                              "content": "  const totalPrice = orderedItems.reduce(",
                              "fontFamily": "Fira Code",
                              "fontSize": 13,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "text",
                              "id": "ZY8Vi",
                              "name": "code9",
                              "fill": "#E6EDF3",
                              "content": "    (sum, item) => sum + item.price, 0",
                              "fontFamily": "Fira Code",
                              "fontSize": 13,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "text",
                              "id": "kRD06",
                              "name": "code10",
                              "fill": "#E6EDF3",
                              "content": "  );",
                              "fontFamily": "Fira Code",
                              "fontSize": 13,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "text",
                              "id": "oWlpq",
                              "name": "code11",
                              "fill": "#E6EDF3",
                              "content": " ",
                              "fontFamily": "Fira Code",
                              "fontSize": 13,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "text",
                              "id": "HC0pT",
                              "name": "code12",
                              "fill": "#6A9955",
                              "content": "  // 총 칼로리 계산",
                              "fontFamily": "Fira Code",
                              "fontSize": 13,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "text",
                              "id": "KfmX0",
                              "name": "code13",
                              "fill": "#E6EDF3",
                              "content": "  const totalCalories = orderedItems.reduce(",
                              "fontFamily": "Fira Code",
                              "fontSize": 13,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "text",
                              "id": "kw8C7",
                              "name": "code14",
                              "fill": "#E6EDF3",
                              "content": "    (sum, item) => sum + item.calories, 0",
                              "fontFamily": "Fira Code",
                              "fontSize": 13,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "text",
                              "id": "yF9Xa",
                              "name": "code15",
                              "fill": "#E6EDF3",
                              "content": "  );",
                              "fontFamily": "Fira Code",
                              "fontSize": 13,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "text",
                              "id": "AQFvZ",
                              "name": "code16",
                              "fill": "#E6EDF3",
                              "content": " ",
                              "fontFamily": "Fira Code",
                              "fontSize": 13,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "text",
                              "id": "35olu",
                              "name": "code17",
                              "fill": "#6A9955",
                              "content": "  // 메뉴 이름 추출 및 출력",
                              "fontFamily": "Fira Code",
                              "fontSize": 13,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "text",
                              "id": "Uay0x",
                              "name": "code18",
                              "fill": "#E6EDF3",
                              "content": "  const names = orderedItems.map(item => item.name);",
                              "fontFamily": "Fira Code",
                              "fontSize": 13,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "text",
                              "id": "mriMb",
                              "name": "code19",
                              "fill": "#E6EDF3",
                              "content": "  console.log(`주문 메뉴: ${names.join(', ')}`);",
                              "fontFamily": "Fira Code",
                              "fontSize": 13,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "text",
                              "id": "gdlwu",
                              "name": "code20",
                              "fill": "#E6EDF3",
                              "content": "  console.log(`총 금액: ${totalPrice}원`);",
                              "fontFamily": "Fira Code",
                              "fontSize": 13,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "text",
                              "id": "IA0df",
                              "name": "code21",
                              "fill": "#E6EDF3",
                              "content": "  console.log(`총 칼로리: ${totalCalories}kcal`);",
                              "fontFamily": "Fira Code",
                              "fontSize": 13,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "text",
                              "id": "HRBig",
                              "name": "code22",
                              "fill": "#E6EDF3",
                              "content": " ",
                              "fontFamily": "Fira Code",
                              "fontSize": 13,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "text",
                              "id": "pYFbW",
                              "name": "code23",
                              "fill": "#6A9955",
                              "content": "  // 거스름돈 계산",
                              "fontFamily": "Fira Code",
                              "fontSize": 13,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "text",
                              "id": "4Ec3W",
                              "name": "code24",
                              "fill": "#E6EDF3",
                              "content": "  const change = money - totalPrice;",
                              "fontFamily": "Fira Code",
                              "fontSize": 13,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "text",
                              "id": "k6rSm",
                              "name": "code25",
                              "fill": "#E6EDF3",
                              "content": "  console.log(`거스름돈: ${change}원`);",
                              "fontFamily": "Fira Code",
                              "fontSize": 13,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "text",
