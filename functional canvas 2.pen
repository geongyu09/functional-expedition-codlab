                    },
                    {
                      "type": "text",
                      "id": "ekuS6",
                      "name": "c11",
                      "fill": "#E6EDF3",
                      "content": "function filterElementByKey(items, key){",
                      "fontFamily": "JetBrains Mono",
                      "fontSize": 11,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "7BGqB",
                      "name": "c12",
                      "fill": "#E6EDF3",
                      "content": "\t let names = [];",
                      "fontFamily": "JetBrains Mono",
                      "fontSize": 11,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "C0nEH",
                      "name": "c13",
                      "fill": "#E6EDF3",
                      "content": "  for (let i = 0; i < items.length; i++) {",
                      "fontFamily": "JetBrains Mono",
                      "fontSize": 11,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "k5K9X",
                      "name": "c14",
                      "fill": "#E6EDF3",
                      "content": "    names.push(items[i][key]);",
                      "fontFamily": "JetBrains Mono",
                      "fontSize": 11,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "4toFD",
                      "name": "c15",
                      "fill": "#E6EDF3",
                      "content": "  }",
                      "fontFamily": "JetBrains Mono",
                      "fontSize": 11,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "xDdun",
                      "name": "c16",
                      "fill": "#E6EDF3",
