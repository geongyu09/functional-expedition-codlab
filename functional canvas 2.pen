                    },
                    {
                      "type": "text",
                      "id": "Cb5fh",
                      "name": "l5",
                      "fill": "#E6EDF3",
                      "content": "  const availableMenus = filterMenuList(menuList, money);",
                      "fontFamily": "JetBrains Mono",
                      "fontSize": 11,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "KFykF",
