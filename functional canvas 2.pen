                              "children": [
                                {
                                  "type": "text",
                                  "id": "I4Jrw",
                                  "name": "rc1",
                                  "fill": "#6A9955",
                                  "content": "// String Utilities",
                                  "lineHeight": 1.5,
                                  "fontFamily": "Fira Code",
                                  "fontSize": 13,
                                  "fontWeight": "normal"
                                },
                                {
                                  "type": "text",
                                  "id": "mCc7j",
                                  "name": "rc2",
                                  "fill": "#6A9955",
                                  "content": "// Common string operations",
                                  "lineHeight": 1.5,
                                  "fontFamily": "Fira Code",
                                  "fontSize": 13,
                                  "fontWeight": "normal"
                                },
                                {
                                  "type": "text",
                                  "id": "Xueay",
                                  "name": "rc3",
                                  "fill": "#E6EDF3",
                                  "content": " ",
                                  "lineHeight": 1.5,
                                  "fontFamily": "Fira Code",
                                  "fontSize": 13,
                                  "fontWeight": "normal"
                                },
                                {
                                  "type": "text",
                                  "id": "9WzOS",
                                  "name": "rc4",
                                  "fill": "#E6EDF3",
                                  "content": "function capitalize(str) {",
                                  "lineHeight": 1.5,
                                  "fontFamily": "Fira Code",
                                  "fontSize": 13,
                                  "fontWeight": "normal"
                                },
                                {
                                  "type": "text",
                                  "id": "MaFe6",
                                  "name": "rc5",
                                  "fill": "#E6EDF3",
                                  "content": "  if (!str) return '';",
                                  "lineHeight": 1.5,
                                  "fontFamily": "Fira Code",
                                  "fontSize": 13,
                                  "fontWeight": "normal"
                                },
                                {
                                  "type": "text",
                                  "id": "xwslE",
                                  "name": "rc6",
                                  "fill": "#E6EDF3",
                                  "content": "  return str.charAt(0)",
                                  "lineHeight": 1.5,
                                  "fontFamily": "Fira Code",
                                  "fontSize": 13,
                                  "fontWeight": "normal"
                                },
                                {
                                  "type": "text",
                                  "id": "xb7Mb",
                                  "name": "rc7",
                                  "fill": "#E6EDF3",
                                  "content": "    .toUpperCase()",
                                  "lineHeight": 1.5,
                                  "fontFamily": "Fira Code",
                                  "fontSize": 13,
                                  "fontWeight": "normal"
                                },
                                {
                                  "type": "text",
                                  "id": "m1UG7",
                                  "name": "rc8",
                                  "fill": "#E6EDF3",
                                  "content": "    + str.slice(1);",
                                  "lineHeight": 1.5,
                                  "fontFamily": "Fira Code",
                                  "fontSize": 13,
                                  "fontWeight": "normal"
                                },
                                {
                                  "type": "text",
                                  "id": "FDO6M",
                                  "name": "rc9",
                                  "fill": "#E6EDF3",
                                  "content": "}",
                                  "lineHeight": 1.5,
                                  "fontFamily": "Fira Code",
                                  "fontSize": 13,
                                  "fontWeight": "normal"
                                },
                                {
                                  "type": "text",
                                  "id": "zhsRZ",
                                  "name": "rc10",
                                  "fill": "#E6EDF3",
                                  "content": " ",
                                  "lineHeight": 1.5,
                                  "fontFamily": "Fira Code",
                                  "fontSize": 13,
                                  "fontWeight": "normal"
                                },
                                {
                                  "type": "text",
                                  "id": "WQsLJ",
                                  "name": "rc11",
                                  "fill": "#E6EDF3",
                                  "content": "function truncate(str, len) {",
                                  "lineHeight": 1.5,
                                  "fontFamily": "Fira Code",
                                  "fontSize": 13,
                                  "fontWeight": "normal"
                                },
                                {
                                  "type": "text",
                                  "id": "0BYGA",
                                  "name": "rc12",
                                  "fill": "#E6EDF3",
                                  "content": "  if (str.length <= len) {",
                                  "lineHeight": 1.5,
                                  "fontFamily": "Fira Code",
                                  "fontSize": 13,
                                  "fontWeight": "normal"
                                },
                                {
                                  "type": "text",
                                  "id": "3FxFy",
                                  "name": "rc13",
                                  "fill": "#E6EDF3",
                                  "content": "    return str;",
                                  "lineHeight": 1.5,
