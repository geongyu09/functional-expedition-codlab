                    },
                    {
                      "type": "text",
                      "id": "oVHeR",
                      "name": "c7",
                      "fill": "#E6EDF3",
                      "content": "function multiply(a, b){",
                      "fontFamily": "JetBrains Mono",
                      "fontSize": 11,
