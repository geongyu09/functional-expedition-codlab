                        {
                          "type": "text",
                          "id": "lQwJM",
                          "name": "l1",
                          "fill": "#E6EDF3",
                          "content": "function processOrder(menuList, orderedMenus, money) {",
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 11,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "rQumE",
                          "name": "l2",
                          "fill": "#8B949E",
                          "content": "  // 구매 가능한 메뉴 필터링",
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 11,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "hZwIU",
                          "name": "l3",
                          "fill": "#E6EDF3",
                          "content": "  const availableMenus = filterMenuList(menuList, money);",
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 11,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "is7qf",
                          "name": "l4",
                          "fill": "#E6EDF3",
                          "content": " ",
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 11,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "XPyTE",
                          "name": "l5",
                          "fill": "#8B949E",
                          "content": "  // '구매 가능한 메뉴' 중에서 주문한 메뉴 정보 가져오기",
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 11,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "iRsCw",
                          "name": "l6",
                          "fill": "#E6EDF3",
                          "content": "  const orderedItems = getOrderedItems(availableMenus, orderedMenus);",
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 11,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "hswX8",
                          "name": "l7",
                          "fill": "#E6EDF3",
                          "content": " ",
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 11,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "BfjSk",
                          "name": "l8",
                          "fill": "#8B949E",
                          "content": "  // 총 주문 금액 계산",
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 11,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "qgAhf",
                          "name": "l9",
                          "fill": "#E6EDF3",
                          "content": "  const totalPrice = calculateTotalPrice(orderedItems);",
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 11,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "1PtFK",
                          "name": "l10",
                          "fill": "#E6EDF3",
                          "content": " ",
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 11,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "XuAXI",
                          "name": "l11",
                          "fill": "#8B949E",
                          "content": "  // 총 칼로리 계산",
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 11,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "uNimq",
                          "name": "l12",
                          "fill": "#E6EDF3",
                          "content": "  const totalKcal = calculateTotalKcal(orderedItems);",
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 11,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "CBDM5",
                          "name": "l13",
                          "fill": "#E6EDF3",
                          "content": " ",
